# Signtral CMS Nginx Configuration Example
# Place this in /etc/nginx/sites-available/signtral and link to sites-enabled

server {
    listen 80;
    server_name signtral.info; # Replace with your domain

    # Redirect HTTP to HTTPS (uncomment after installing SSL)
    # return 301 https://$host$request_uri;

    location / {
        proxy_pass http://localhost:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Socket.io support
        proxy_set_header X-NginX-Proxy true;
    }

    # Static file optimization
    location /public/ {
        alias /path/to/your/app/public/;
        expires 30d;
        add_header Cache-Control "public, no-transform";
    }

    # Increase upload size for media
    client_max_body_size 100M;
}

# SSL Example (Certbot will manage this automatically)
# server {
#     listen 443 ssl;
#     server_name yourdomain.com;
#     ...
# }
