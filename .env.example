# ─── XIBO CMS API CREDENTIALS ─────────────────────────────────────────────────
XIBO_BASE_URL=https://cms.signtral.info/
XIBO_CLIENT_ID=your_client_id_here
XIBO_CLIENT_SECRET=your_client_secret_here

# ─── DATABASE CONFIGURATION (MySQL) ───────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=xibo_crm

# ─── AUTHENTICATION (Better Auth & JWT) ───────────────────────────────────────
# Better Auth Secret (32-character random string recommended)
BETTER_AUTH_SECRET=your_secret_here
BETTER_AUTH_URL=https://signtral.info
JWT_SECRET=super_secret_signing_key_change_me

# ─── SERVER CONFIGURATION ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── XIBO RESILIENCE (CIRCUIT BREAKER) ─────────────────────────────────────────
XIBO_RETRY_THRESHOLD=3
CIRCUIT_RESET_MS=60000
XIBO_REQUEST_TIMEOUT=8000

# ─── PORTAL URLS (Aligned with Production) ────────────────────────────────────
BACKEND_URL=https://signtral.info
WEB_APP_URL=https://signtral.info
ADMIN_URL=https://signtral.info
BRAND_URL=https://signtral.info
PARTNER_URL=https://signtral.info
