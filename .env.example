# ─── Runtime ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production   # set to 'development' locally

# ─── Xibo CMS API Credentials ─────────────────────────────────────────────────
XIBO_BASE_URL=https://your-xibo-instance.example.com/
XIBO_CLIENT_ID=your_client_id_here
XIBO_CLIENT_SECRET=your_client_secret_here

# ─── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET=your-random-64-char-secret-here

# ─── Better Auth ──────────────────────────────────────────────────────────────
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=your-random-32-char-secret-here
BETTER_AUTH_API_KEY=your-better-auth-api-key-here

# ─── MySQL Database ───────────────────────────────────────────────────────────
# All four variables are REQUIRED — the server will refuse to start if any is missing.
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=xibo_crm

# ─── System Defaults ──────────────────────────────────────────────────────────
PLACEHOLDER_MEDIA_ID=1

# ─── URLs ─────────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:3000
WEB_APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3000
BRAND_URL=http://localhost:3000
PARTNER_URL=http://localhost:3000
