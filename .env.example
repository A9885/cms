# ─── XIBO CMS API CREDENTIALS ─────────────────────────────────────────────────
XIBO_BASE_URL=https://cms.signtral.info/
XIBO_CLIENT_ID=your_client_id_here
XIBO_CLIENT_SECRET=your_client_secret_here

# ─── DATABASE CONFIGURATION (MySQL) ───────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=xibo_crm

# ─── AUTHENTICATION (Better Auth & JWT) ───────────────────────────────────────
# Better Auth Secret (32-character random string recommended)
BETTER_AUTH_SECRET=9sK8vR4mN2pQ3xZ7aL5jW1hT6uY0iE4o
BETTER_AUTH_URL=http://localhost:3000
JWT_SECRET=super_secret_signing_key_change_me

# ─── SERVER CONFIGURATION ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── XIBO RESILIENCE (CIRCUIT BREAKER) ─────────────────────────────────────────
# Number of consecutive failures before opening the circuit
XIBO_RETRY_THRESHOLD=3
# How long to wait (ms) before attempting to reconnect after an outage
CIRCUIT_RESET_MS=60000
# Timeout for individual Xibo API requests (ms)
XIBO_REQUEST_TIMEOUT=8000

# ─── PORTAL URLS (Diagnostic/CORS) ───────────────────────────────────────────
BACKEND_URL=http://localhost:3000
WEB_APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:3000
BRAND_URL=http://localhost:3000
PARTNER_URL=http://localhost:3000
